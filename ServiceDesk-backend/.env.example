# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
MONGODB_URI=mongodb://localhost:27017/prep_manager
MONGODB_TEST_URI=mongodb://localhost:27017/prep_manager_test

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Firebase Cloud Messaging (Optional)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# SMS Configuration (Optional)
SMS_API_KEY=
SMS_PROVIDER=twilio

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# Timezone
TZ=Asia/Riyadh

# MinIO Object Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_USE_SSL=false
MINIO_DEFAULT_BUCKET=servicedesk-files
MINIO_PUBLIC_URL=http://localhost:9000
# Base URL
BASE_URL=http://localhost:5000

# Redis (Optional)
REDIS_URL=redis://localhost:6379

# Kafka / Redpanda
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=servicedesk-backend
KAFKA_CONSUMER_GROUP=servicedesk-consumers
KAFKA_CONNECTION_TIMEOUT=3000
KAFKA_REQUEST_TIMEOUT=30000

# Kafka SASL Auth (for managed clusters — Confluent, AWS MSK, etc.)
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL_ENABLED=false

# JWT Refresh Secret (Optional - defaults to JWT_SECRET if not set)
JWT_REFRESH_SECRET=

# ============================================================
# ARCHITECTURE — Database Strategy & Feature Flags
# ============================================================

# PostgreSQL (used when DB_STRATEGY_* = postgresql)
POSTGRES_USER=servicedesk
POSTGRES_PASSWORD=servicedesk123
POSTGRES_DB=servicedesk
POSTGRES_URL=postgresql://servicedesk:servicedesk123@localhost:5432/servicedesk

# Per-module database strategy (mongodb or postgresql)
DB_STRATEGY_ITSM=mongodb
DB_STRATEGY_PM=mongodb
DB_STRATEGY_FORMS=mongodb
DB_STRATEGY_WORKFLOW=mongodb
DB_STRATEGY_PLATFORM=mongodb
DB_STRATEGY_ANALYTICS=mongodb

# Workflow Engine mode (local = in-process, remote = microservice)
WORKFLOW_ENGINE_MODE=local

# ============================================================
# INTEGRATIONS (all disabled by default)
# ============================================================

# Email (SMTP)
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@servicedesk.local
SMTP_FROM_NAME=ServiceDesk

# Slack
SLACK_ENABLED=false
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_DEFAULT_CHANNEL=#servicedesk
SLACK_ALERT_CHANNEL=#servicedesk-alerts

# Microsoft Teams
TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=

# GitHub
GITHUB_ENABLED=false
GITHUB_WEBHOOK_SECRET=
GITHUB_DEFAULT_ORG=

# GitLab
GITLAB_ENABLED=false
GITLAB_WEBHOOK_SECRET=
GITLAB_DEFAULT_ORG=

# CI/CD (Generic Webhook)
CICD_WEBHOOK_ENABLED=false
CICD_WEBHOOK_SECRET=
CICD_DEFAULT_ORG=

# Monitoring — Alert Webhook (Prometheus/Grafana/Datadog)
ALERT_WEBHOOK_ENABLED=false
ALERT_WEBHOOK_SECRET=
ALERT_WEBHOOK_DEFAULT_ORG=

# Monitoring — Heartbeat / Uptime
HEARTBEAT_ENABLED=false
HEARTBEAT_SECRET=
HEARTBEAT_DEFAULT_ORG=
