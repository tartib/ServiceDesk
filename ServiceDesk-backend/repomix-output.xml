  async getExecutionStats() {
    const pool = getPool();
    const result = await pool.query(
      `SELECT "status" AS "_id", COUNT(*)::int AS count, AVG("duration_ms")::real AS "avgDuration"
       FROM "itsm_rule_execution_logs"
       GROUP BY "status"`,
