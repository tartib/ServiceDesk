import { Response } from 'express';
import { FilterQuery } from 'mongoose';
import logger from '../../../utils/logger';
import Project from '../models/Project';
import type { IProject } from '../models/Project';
import PMTeam from '../models/Team';
import Organization from '../models/Organization';
import User from '../../../models/User';
import Task from '../models/Task';
import { PMAuthRequest as Request, ApiResponse, ProjectRole, MethodologyCode } from '../../../types/pm';
import * as permissions from '../../../utils/pm/permissions';
import { getPmRepos, isPmPostgres } from '../infrastructure/repositories';
import { PgProjectRepository } from '../infrastructure/repositories/PgProjectRepository';
import { PgTaskRepository } from '../infrastructure/repositories/PgTaskRepository';

export const createProject = async (req: Request, res: Response): Promise<void> => {
  try {

    const userId = req.user?.id;
    let organizationId = req.user?.organizationId;

    const { key, name, description, methodology, startDate, targetEndDate } = req.body;

    // If no organization, create or get default one for this user
    if (!organizationId) {
      let defaultOrg = await Organization.findOne({ createdBy: userId });
      if (!defaultOrg) {
        defaultOrg = new Organization({
          name: 'Default Organization',
          slug: `org-${userId}`,
          createdBy: userId,
        });
        await defaultOrg.save();
      }
      organizationId = defaultOrg._id.toString();
    }

    const usePg = isPmPostgres();

    // Check for duplicate key
    if (usePg) {
      const repo = getPmRepos().project as PgProjectRepository;
      const existing = await repo.findByKey(organizationId, key.toUpperCase());
      if (existing) {
        res.status(400).json({ success: false, error: 'Project key already exists in this organization' } as ApiResponse);
        return;
      }
    } else {
      const existingProject = await Project.findOne({ organizationId, key: key.toUpperCase() });
      if (existingProject) {
        res.status(400).json({
          success: false,
          error: 'Project key already exists in this organization',
        } as ApiResponse);
        return;
      }
    }

    const projectData = {
      organizationId,
      key: key.toUpperCase(),
      name,
      description,
      methodologyCode: methodology || MethodologyCode.SCRUM,
      members: [
        {
          userId,
          role: ProjectRole.LEAD,
          permissions: ['*'],
          addedAt: new Date(),
        },
      ],
      startDate,
      targetEndDate,
      createdBy: userId,
    };

    let project: any;
    if (usePg) {
      const repo = getPmRepos().project as PgProjectRepository;
      project = await repo.create(projectData as any);
    } else {
      const mongoProject = new Project({
        ...projectData,
        methodology: { code: projectData.methodologyCode },
      });
      await mongoProject.save();
      project = mongoProject;
    }

    res.status(201).json({
      success: true,
      data: { project },
      message: 'Project created successfully',
    } as ApiResponse);
  } catch (error) {
    logger.error('Create project error:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to create project',
    } as ApiResponse);
  }
};

export const getProjects = async (req: Request, res: Response): Promise<void> => {
  try {
    const userId = req.user?.id;
    const organizationId = req.user?.organizationId;

    const { status, methodology, page = 1, limit = 20 } = req.query;
    const pageNum = Number(page);
    const limitNum = Number(limit);

    // ── PostgreSQL path ──
    if (isPmPostgres()) {
      const repo = getPmRepos().project as PgProjectRepository;
      const result = await repo.searchProjects(
        { status, methodology },
        userId || '',
        organizationId,
        pageNum,
        limitNum,
      );
      res.status(200).json({
        success: true,
        data: {
          projects: result.data,
          pagination: {
            total: result.total,
            page: result.page,
            limit: result.limit,
            totalPages: result.totalPages,
            hasNext: (result.page * result.limit) < result.total,
            hasPrev: result.page > 1,
          },
        },
      } as ApiResponse);
      return;
    }

    // ── MongoDB path ──
    // Build query - if no organizationId, show projects where user is a member
    const query: FilterQuery<IProject> = organizationId 
      ? {
          organizationId,
          $or: [
            { 'members.userId': userId },
            { 'settings.visibility': 'public' },
          ],
        }
      : {
          $or: [
            { 'members.userId': userId },
            { createdBy: userId },
            { 'settings.visibility': 'public' },
          ],
        };

    if (status) query.status = status as any;
    if (methodology) query['methodology.code'] = methodology;

    const skip = (pageNum - 1) * limitNum;

    const [projects, total] = await Promise.all([
      Project.find(query)
        .populate('members.userId', 'name profile.firstName profile.lastName profile.avatar email')
        .populate('createdBy', 'name profile.firstName profile.lastName email')
        .populate('teams.teamId', 'name')
        .sort({ updatedAt: -1 })
        .skip(skip)
        .limit(limitNum),
      Project.countDocuments(query),
    ]);

    res.status(200).json({
      success: true,
      data: {
        projects,
        pagination: {
          total,
          page: pageNum,
          limit: limitNum,
          totalPages: Math.ceil(total / limitNum),
          hasNext: skip + projects.length < total,
          hasPrev: pageNum > 1,
        },
      },
    } as ApiResponse);
  } catch (error) {
    logger.error('Get projects error:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to fetch projects',
    } as ApiResponse);
  }
};

export const getProject = async (req: Request, res: Response): Promise<void> => {
  try {
    const { projectId } = req.params;
    const userId = req.user?.id;

    let project: any;
    if (isPmPostgres()) {
      const repo = getPmRepos().project as PgProjectRepository;
      project = await repo.findById(projectId);
    } else {
      project = await Project.findById(projectId)
        .populate('members.userId', 'profile.firstName profile.lastName profile.avatar email')
        .populate('teams.teamId', 'name members')
        .populate('createdBy', 'profile.firstName profile.lastName');
    }

    if (!project) {
      res.status(404).json({
        success: false,
        error: 'Project not found',
      } as ApiResponse);
      return;
    }

    const members = project.members || [];
    const isMember = members.some((m: any) => {
      const memberUserId = m.userId as any;
      const memberId = memberUserId?._id?.toString() || memberUserId?.toString();
      return memberId === userId;
    });
    const visibility = project.settings?.visibility || project.settingsVisibility || 'private';
    const isPublic = visibility === 'public';

    if (!isMember && !isPublic) {
      res.status(403).json({
        success: false,
        error: 'Access denied',
      } as ApiResponse);
      return;
    }

    res.status(200).json({
      success: true,
      data: { project },
    } as ApiResponse);
  } catch (error) {
    logger.error('Get project error:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to fetch project',
    } as ApiResponse);
  }
};

export const updateProject = async (req: Request, res: Response): Promise<void> => {
  try {

    const { projectId } = req.params;
    const userId = req.user?.id;
    const usePg = isPmPostgres();

    // ── PostgreSQL path ──
    if (usePg) {
      const repo = getPmRepos().project as PgProjectRepository;
      let project = await repo.findById(projectId);
      if (!project) {
        res.status(404).json({ success: false, error: 'Project not found' } as ApiResponse);
        return;
      }
      const members = project.members || [];
      const member = members.find((m: any) => m.userId?.toString() === userId);
      if (!member || ![ProjectRole.LEAD, ProjectRole.MANAGER].includes(member.role as ProjectRole)) {
        res.status(403).json({ success: false, error: 'Insufficient permissions' } as ApiResponse);
        return;
      }
      const { name, description, methodology, startDate, targetEndDate, settings, health, priority, escalated, escalationReason } = req.body;
      const updates: Record<string, any> = {};
      if (name) updates.name = name;
      if (description !== undefined) updates.description = description;
      if (methodology) updates.methodologyCode = methodology;
      if (startDate) updates.startDate = startDate;
      if (targetEndDate) updates.targetEndDate = targetEndDate;
      if (settings?.visibility) updates['settings.visibility'] = settings.visibility;
      if (settings?.allowExternal !== undefined) updates['settings.allowExternal'] = settings.allowExternal;
      if (health) updates.health = health;
      if (priority) updates.priority = priority;
      if (escalated !== undefined) updates.escalated = escalated;
      if (escalationReason !== undefined) updates.escalationReason = escalationReason;

      project = await repo.updateById(projectId, updates as any);
      res.status(200).json({ success: true, data: { project }, message: 'Project updated successfully' } as ApiResponse);
      return;
    }

    // ── MongoDB path ──
    const project = await Project.findById(projectId);

    if (!project) {
      res.status(404).json({
        success: false,
        error: 'Project not found',
      } as ApiResponse);
      return;
    }

    const member = project.members.find((m) => m.userId?.toString() === userId);
    if (!member || ![ProjectRole.LEAD, ProjectRole.MANAGER].includes(member.role as ProjectRole)) {
      res.status(403).json({
        success: false,
        error: 'Insufficient permissions',
      } as ApiResponse);
      return;
    }

    const { name, description, methodology, startDate, targetEndDate, settings, health, priority, escalated, escalationReason } = req.body;

    if (name) project.name = name;
    if (description !== undefined) project.description = description;
    if (methodology) project.methodology.code = methodology;
    if (startDate) project.startDate = startDate;
    if (targetEndDate) project.targetEndDate = targetEndDate;
    if (settings) project.settings = { ...project.settings, ...settings };
    if (health) project.health = health;
    if (priority) project.priority = priority;
    if (escalated !== undefined) project.escalated = escalated;
    if (escalationReason !== undefined) project.escalationReason = escalationReason;

    await project.save();

    res.status(200).json({
      success: true,
      data: { project },
      message: 'Project updated successfully',
    } as ApiResponse);
  } catch (error) {
    logger.error('Update project error:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to update project',
    } as ApiResponse);
  }
};

export const deleteProject = async (req: Request, res: Response): Promise<void> => {
  try {
    const { projectId } = req.params;
    const userId = req.user?.id;

    // ── PostgreSQL path ──
