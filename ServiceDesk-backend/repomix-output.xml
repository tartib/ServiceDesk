import { Response } from 'express';
import mongoose from 'mongoose';
import logger from '../../../utils/logger';
import Sprint from '../models/Sprint';
import Task from '../models/Task';
import Project from '../models/Project';
import { PMAuthRequest, ApiResponse, StatusCategory } from '../../../types/pm';
import { notifyProjectMembers } from './notificationHelper';
import { getPmRepos, isPmPostgres } from '../infrastructure/repositories';
import { PgSprintRepository } from '../infrastructure/repositories/PgSprintRepository';
import { PgTaskRepository } from '../infrastructure/repositories/PgTaskRepository';
import { PgProjectRepository } from '../infrastructure/repositories/PgProjectRepository';

export const createSprint = async (req: PMAuthRequest, res: Response): Promise<void> => {
  try {

    const userId = req.user?.id;
    const { projectId } = req.params;
    const usePg = isPmPostgres();

    // Get organizationId from project
    let organizationId: string | undefined;
    if (usePg) {
      const projRepo = getPmRepos().project as PgProjectRepository;
      const project = await projRepo.findById(projectId);
      if (!project) {
        res.status(404).json({ success: false, error: 'Project not found' } as ApiResponse);
        return;
      }
      organizationId = project.organizationId || project.organization_id || req.user?.organizationId;
    } else {
      const project = await Project.findById(projectId);
      if (!project) {
        res.status(404).json({ success: false, error: 'Project not found' } as ApiResponse);
        return;
      }
      organizationId = project.organizationId?.toString() || req.user?.organizationId;
    }

    const { name, goal, startDate, endDate, capacity } = req.body;

    // ── PostgreSQL path ──
    if (usePg) {
      const sprintRepo = getPmRepos().sprint as PgSprintRepository;
      const nextNumber = await sprintRepo.getNextNumber(projectId);
      const sprint = await sprintRepo.create({
        projectId,
        organizationId,
        name: name || `Sprint ${nextNumber}`,
        goal,
        number: nextNumber,
        status: 'planning',
        startDate,
        endDate,
        capacityPlanned: capacity?.planned || 0,
        capacityCommitted: capacity?.committed || 0,
        createdBy: userId,
      } as any);
      res.status(201).json({ success: true, data: { sprint }, message: 'Sprint created successfully' } as ApiResponse);
      return;
    }

    // ── MongoDB path ──
    const lastSprint = await Sprint.findOne({ projectId }).sort({ number: -1 });
    const nextNumber = (lastSprint?.number || 0) + 1;

    const sprint = new Sprint({
      projectId,
      organizationId,
      name: name || `Sprint ${nextNumber}`,
      goal,
      number: nextNumber,
      status: 'planning',
      startDate,
      endDate,
      capacity: capacity || { planned: 0, committed: 0 },
      createdBy: userId,
    });

    await sprint.save();

    res.status(201).json({
      success: true,
      data: { sprint },
      message: 'Sprint created successfully',
    } as ApiResponse);
  } catch (error) {
    logger.error('Create sprint error:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to create sprint',
    } as ApiResponse);
  }
};

export const getSprints = async (req: PMAuthRequest, res: Response): Promise<void> => {
  try {
    const { projectId } = req.params;
    const { status } = req.query;

    // ── PostgreSQL path ──
    if (isPmPostgres()) {
      const sprintRepo = getPmRepos().sprint as PgSprintRepository;
      const taskRepo = getPmRepos().task as PgTaskRepository;

      const statusFilter = status ? (status as string).includes(',') ? (status as string).split(',').map(s => s.trim()) : (status as string) : undefined;
      const sprints = await sprintRepo.findByProject(projectId, statusFilter);

      const sprintsWithStats = await Promise.all(
        sprints.map(async (sprint: any) => {
          const sid = sprint._id || sprint.id;
          const cats = await taskRepo.countByStatusCategory(sid);
          const totalTasks = Object.values(cats).reduce((s: number, v: any) => s + v, 0);
          const completedTasks = cats['done'] || 0;
          // story points would need a custom query; use 0 as placeholder
          return {
            ...sprint,
            stats: { totalTasks, completedTasks, totalPoints: 0, completedPoints: 0 },
            progress: totalTasks > 0 ? Math.round((completedTasks / totalTasks) * 100) : 0,
          };
        })
      );

      res.status(200).json({ success: true, data: { sprints: sprintsWithStats } } as ApiResponse);
      return;
    }

    // ── MongoDB path ──
    // Build query - handle projectId as string (Mongoose will cast it)
    const query: Record<string, unknown> = { projectId };
    if (status) {
      const statusStr = status as string;
      query.status = statusStr.includes(',') ? { $in: statusStr.split(',').map(s => s.trim()) } : statusStr;
    }

    // Find all sprints for this project
    const sprints = await Sprint.find(query).sort({ number: -1 });
    
    // If no sprints found, also try to find any sprints (for debugging)
    if (sprints.length === 0) {
      const allSprints = await Sprint.find({}).limit(5);
      console.log(`No sprints found for project ${projectId}. Total sprints in DB: ${allSprints.length}`);
    }

    // Get task counts for each sprint
    const sprintsWithStats = await Promise.all(
      sprints.map(async (sprint) => {
        const tasks = await Task.find({ sprintId: sprint._id });
        const totalTasks = tasks.length;
        const completedTasks = tasks.filter((t) => t.status.category === StatusCategory.DONE).length;
        const totalPoints = tasks.reduce((sum, t) => sum + (t.storyPoints || 0), 0);
        const completedPoints = tasks
          .filter((t) => t.status.category === StatusCategory.DONE)
          .reduce((sum, t) => sum + (t.storyPoints || 0), 0);

        // Calculate progress percentage
        const progressByTasks = totalTasks > 0 ? Math.round((completedTasks / totalTasks) * 100) : 0;
        const progressByPoints = totalPoints > 0 ? Math.round((completedPoints / totalPoints) * 100) : 0;

        return {
          ...sprint.toJSON(),
          stats: {
            totalTasks,
            completedTasks,
            totalPoints,
            completedPoints,
          },
          progress: progressByPoints > 0 ? progressByPoints : progressByTasks,
        };
      })
    );

    res.status(200).json({
      success: true,
      data: { sprints: sprintsWithStats },
    } as ApiResponse);
  } catch (error) {
    logger.error('Get sprints error:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to fetch sprints',
    } as ApiResponse);
  }
};

