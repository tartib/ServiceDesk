  userId: string;
  correlationId?: string;
}

function createEvent<T>(
  type: string,
  data: T,
  context: EventContext,
  changes?: FieldChange[]
): DomainEvent<T> {
  return {
    id: uuidv4(),
    type,
    timestamp: new Date().toISOString(),
    version: '1.0',
    organizationId: context.organizationId,
    userId: context.userId,
    correlationId: context.correlationId,
    data,
    changes,
  };
}

