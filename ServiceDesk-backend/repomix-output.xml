      version: String,
      license_key: String,
      license_type: { type: String, enum: ['perpetual', 'subscription', 'open_source', 'trial'] },
      license_count: Number,
      expiry_date: Date,
    },
    network_info: {
      ip_address: String,
      mac_address: String,
      hostname: String,
      domain: String,
    },
