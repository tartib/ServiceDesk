export class PgRuleExecutionLogRepository extends PostgresRepository<any> {
  constructor() {
    super({
      tableName: 'itsm_rule_execution_logs',
      columnMap: {
        'ruleId': 'rule_id',
        'ruleName': 'rule_name',
        'triggerTicketId': 'trigger_ticket_id',
        'triggerType': 'trigger_type',
        'executionId': 'execution_id',
