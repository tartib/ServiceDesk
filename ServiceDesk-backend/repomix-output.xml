// CI Criticality
export enum CICriticality {
  CRITICAL = 'critical',
  HIGH = 'high',
  MEDIUM = 'medium',
  LOW = 'low',
  TRIVIAL = 'trivial',
}

// CMDB Configuration Item Interface
export interface IConfigurationItem extends Document {
