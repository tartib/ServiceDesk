  PROVIDES = 'provides',
  REPLICATES = 'replicates',
  CONSUMES = 'consumes',
}

// CI Status
export enum CIStatus {
  ACTIVE = 'active',
  INACTIVE = 'inactive',
  RETIRED = 'retired',
  MAINTENANCE = 'maintenance',
  PENDING = 'pending',
  DECOMMISSIONED = 'decommissioned',
}

// CI Type
export enum CIType {
  HARDWARE = 'hardware',
  SOFTWARE = 'software',
  NETWORK = 'network',
  SERVICE = 'service',
  VIRTUAL_MACHINE = 'virtual_machine',
  DATABASE = 'database',
  APPLICATION = 'application',
  SERVER = 'server',
