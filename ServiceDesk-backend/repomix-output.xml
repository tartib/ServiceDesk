        tasksByStatus[statusId] = [];
      }
      tasksByStatus[statusId].push(task);
    }

    res.status(200).json({
      success: true,
      data: { tasks, tasksByStatus },
    } as ApiResponse);
  } catch (error) {
    logger.error('Get board tasks error:', error);
