<file path="docker-compose.yml">
version: '3.8'

services:
  # ── MongoDB ────────────────────────────────────────────────
  mongodb:
    image: mongo:7.0
    container_name: servicedesk-db
    restart: unless-stopped
    environment:
      MONGO_INITDB_ROOT_USERNAME: ${MONGO_ROOT_USERNAME:-admin}
      MONGO_INITDB_ROOT_PASSWORD: ${MONGO_ROOT_PASSWORD:-admin123}
      MONGO_INITDB_DATABASE: servicedesk
    ports:
      - "27017:27017"
    volumes:
      - mongodb_data:/data/db
      - mongodb_config:/data/configdb
      - ./scripts/mongo-init:/docker-entrypoint-initdb.d:ro
    networks:
      - servicedesk-network
    healthcheck:
      test: echo 'db.runCommand("ping").ok' | mongosh localhost:27017/test --quiet
      interval: 10s
      timeout: 5s
      retries: 5

  # ── Redis (Cache + Feature Flags + Socket.IO Pub/Sub) ──────
  redis:
    image: redis:7-alpine
    container_name: servicedesk-redis
    restart: unless-stopped
    command: redis-server --appendonly yes --maxmemory 128mb --maxmemory-policy allkeys-lru
    ports:
      - "${REDIS_PORT:-6380}:6379"
    volumes:
      - redis_data:/data
    networks:
      - servicedesk-network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ── MinIO (Object Storage) ─────────────────────────────────
  minio:
    image: minio/minio:latest
    container_name: servicedesk-minio
    restart: unless-stopped
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER:-minioadmin}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD:-minioadmin123}
    ports:
      - "9000:9000"
      - "9001:9001"
    volumes:
      - minio_data:/data
    networks:
      - servicedesk-network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 30s
      timeout: 20s
      retries: 3

  # ── PostgreSQL (Hybrid DB Strategy) ──────────────────────
  postgres:
    image: postgres:16-alpine
    container_name: servicedesk-postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-servicedesk}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-servicedesk123}
      POSTGRES_DB: ${POSTGRES_DB:-servicedesk}
    ports:
      - "${POSTGRES_PORT:-5433}:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./scripts/pg-init:/docker-entrypoint-initdb.d:ro
    networks:
      - servicedesk-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-servicedesk} -d ${POSTGRES_DB:-servicedesk}"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ── Redpanda (Kafka-compatible Event Bus) ──────────────────
  redpanda:
    image: docker.redpanda.com/redpandadata/redpanda:v24.1.1
    container_name: servicedesk-redpanda
    restart: unless-stopped
    command:
      - redpanda
      - start
      - --smp=1
      - --memory=256M
      - --overprovisioned
      - --kafka-addr=internal://0.0.0.0:9092,external://0.0.0.0:19092
      - --advertise-kafka-addr=internal://redpanda:9092,external://localhost:19092
      - --pandaproxy-addr=internal://0.0.0.0:8082,external://0.0.0.0:18082
      - --advertise-pandaproxy-addr=internal://redpanda:8082,external://localhost:18082
      - --schema-registry-addr=internal://0.0.0.0:8081,external://0.0.0.0:18081
      - --mode=dev-container
    ports:
      - "18081:18081"
      - "18082:18082"
      - "19092:19092"
      - "9644:9644"
    volumes:
      - redpanda_data:/var/lib/redpanda/data
    networks:
      - servicedesk-network
    healthcheck:
      test: ["CMD", "rpk", "cluster", "health", "--api-urls", "localhost:9644"]
      interval: 15s
      timeout: 10s
      retries: 5
      start_period: 20s

  # ── Redpanda Console (optional Kafka UI) ───────────────────
  redpanda-console:
    image: docker.redpanda.com/redpandadata/console:v2.4.5
    container_name: servicedesk-redpanda-console
    restart: unless-stopped
    environment:
      CONFIG_FILEPATH: ""
      KAFKA_BROKERS: redpanda:9092
      KAFKA_SCHEMAREGISTRY_ENABLED: "true"
      KAFKA_SCHEMAREGISTRY_URLS: http://redpanda:8081
    ports:
      - "${CONSOLE_PORT:-8085}:8080"
    depends_on:
      redpanda:
        condition: service_healthy
    networks:
      - servicedesk-network
    profiles:
      - tools

  # ── ServiceDesk API ────────────────────────────────────────
  api:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: servicedesk-api
    restart: unless-stopped
    ports:
      - "${PORT:-5000}:5000"
    environment:
      # Core
      NODE_ENV: ${NODE_ENV:-development}
      PORT: 5000
      BASE_URL: ${BASE_URL:-http://localhost:5000}
      CORS_ORIGIN: ${CORS_ORIGIN:-http://localhost:3000}
      LOG_LEVEL: ${LOG_LEVEL:-info}
      TZ: ${TZ:-Asia/Riyadh}

      # Auth
      JWT_SECRET: ${JWT_SECRET:-your_super_secret_jwt_key_change_in_production}
      JWT_EXPIRE: ${JWT_EXPIRE:-7d}
      JWT_REFRESH_SECRET: ${JWT_REFRESH_SECRET:-}
      JWT_REFRESH_EXPIRE: ${JWT_REFRESH_EXPIRE:-30d}

      # MongoDB
      MONGODB_URI: mongodb://${MONGO_ROOT_USERNAME:-admin}:${MONGO_ROOT_PASSWORD:-admin123}@mongodb:27017/servicedesk?authSource=admin

      # Redis
      REDIS_URL: redis://redis:6379

      # PostgreSQL (used when DB_STRATEGY_* = postgresql)
      POSTGRES_URL: postgresql://${POSTGRES_USER:-servicedesk}:${POSTGRES_PASSWORD:-servicedesk123}@postgres:5432/${POSTGRES_DB:-servicedesk}

      # MinIO
      MINIO_ENDPOINT: minio
      MINIO_PORT: 9000
      MINIO_ACCESS_KEY: ${MINIO_ROOT_USER:-minioadmin}
      MINIO_SECRET_KEY: ${MINIO_ROOT_PASSWORD:-minioadmin123}
      MINIO_USE_SSL: "false"
      MINIO_DEFAULT_BUCKET: ${MINIO_DEFAULT_BUCKET:-servicedesk-files}
      MINIO_PUBLIC_URL: ${MINIO_PUBLIC_URL:-http://localhost:9000}

      # Kafka / Redpanda
      KAFKA_ENABLED: ${KAFKA_ENABLED:-true}
      KAFKA_BROKERS: ${KAFKA_BROKERS:-redpanda:9092}
      KAFKA_CLIENT_ID: ${KAFKA_CLIENT_ID:-servicedesk-backend}
      KAFKA_CONSUMER_GROUP: ${KAFKA_CONSUMER_GROUP:-servicedesk-consumers}
      KAFKA_CONNECTION_TIMEOUT: ${KAFKA_CONNECTION_TIMEOUT:-3000}
      KAFKA_REQUEST_TIMEOUT: ${KAFKA_REQUEST_TIMEOUT:-30000}
      KAFKA_SASL_MECHANISM: ${KAFKA_SASL_MECHANISM:-}
      KAFKA_SASL_USERNAME: ${KAFKA_SASL_USERNAME:-}
      KAFKA_SASL_PASSWORD: ${KAFKA_SASL_PASSWORD:-}
      KAFKA_SSL_ENABLED: ${KAFKA_SSL_ENABLED:-false}

      # Database Strategy (per-module: mongodb or postgresql)
      DB_STRATEGY_ITSM: ${DB_STRATEGY_ITSM:-mongodb}
      DB_STRATEGY_PM: ${DB_STRATEGY_PM:-mongodb}
      DB_STRATEGY_FORMS: ${DB_STRATEGY_FORMS:-mongodb}
      DB_STRATEGY_WORKFLOW: ${DB_STRATEGY_WORKFLOW:-mongodb}
      DB_STRATEGY_PLATFORM: ${DB_STRATEGY_PLATFORM:-mongodb}
      DB_STRATEGY_ANALYTICS: ${DB_STRATEGY_ANALYTICS:-mongodb}

      # Workflow Engine Mode (local = in-process, remote = microservice)
      WORKFLOW_ENGINE_MODE: ${WORKFLOW_ENGINE_MODE:-local}

      # Integrations (all disabled by default)
      SMTP_ENABLED: ${SMTP_ENABLED:-false}
      SLACK_ENABLED: ${SLACK_ENABLED:-false}
      TEAMS_ENABLED: ${TEAMS_ENABLED:-false}
      GITHUB_ENABLED: ${GITHUB_ENABLED:-false}
      GITLAB_ENABLED: ${GITLAB_ENABLED:-false}
      CICD_WEBHOOK_ENABLED: ${CICD_WEBHOOK_ENABLED:-false}
      ALERT_WEBHOOK_ENABLED: ${ALERT_WEBHOOK_ENABLED:-false}
      HEARTBEAT_ENABLED: ${HEARTBEAT_ENABLED:-false}
    depends_on:
      mongodb:
        condition: service_healthy
      redis:
        condition: service_healthy
      minio:
        condition: service_healthy
      postgres:
        condition: service_healthy
      redpanda:
        condition: service_healthy
    networks:
      - servicedesk-network
    volumes:
      - ./logs:/app/logs
      - ./uploads:/app/uploads
    healthcheck:
      test: ["CMD", "node", "-e", "require('http').get('http://localhost:5000/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

networks:
  servicedesk-network:
    driver: bridge

volumes:
  mongodb_data:
    driver: local
  mongodb_config:
    driver: local
  redis_data:
    driver: local
  minio_data:
    driver: local
  postgres_data:
    driver: local
  redpanda_data:
    driver: local
