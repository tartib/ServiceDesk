export interface TransitionResponse<T = unknown> {
  success: boolean;
  data: {
    entity: T;
    transition: {
      from: string;
      to: string;
      timestamp: string;
      triggeredBy: string;
    };
    sideEffects?: {
      notifications?: string[];
      events?: string[];
    };
  };
}

// ============================================================
