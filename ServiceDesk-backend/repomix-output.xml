/**
 * Authorization Types
 * 
 * RBAC + ABAC permission model
 */

// ============================================================
// PERMISSION DEFINITIONS
// ============================================================

export type Action = 
  | 'create'
  | 'read'
  | 'update'
  | 'delete'
  | 'transition'
  | 'assign'
  | 'manage';

export type Scope = 
  | 'own'           // Only resources owned/assigned to user
  | 'team'          // Resources within user's team
  | 'project'       // Resources within project
  | 'organization'  // All resources in organization
  | 'all';          // System-wide (super admin)

export interface Permission {
  resource: string;
  action: Action;
  scope: Scope;
  conditions?: PermissionCondition;
}

export interface PermissionCondition {
  statusIn?: string[];
  statusNotIn?: string[];
  typeIn?: string[];
  priorityIn?: string[];
  isOwner?: boolean;
  isAssignee?: boolean;
  isReporter?: boolean;
}

// ============================================================
