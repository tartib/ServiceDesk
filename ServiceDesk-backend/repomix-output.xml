  limit?: number;
  sortBy?: string;
  sortOrder?: 'asc' | 'desc';
}

export interface DateRangeParams {
  startDate?: string;
  endDate?: string;
}

export interface SearchParams extends PaginationParams {
  q?: string;
  status?: string;
  priority?: Priority;
  assignee?: string;
  type?: string;
}
