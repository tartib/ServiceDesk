# ══════════════════════════════════════════════════════════
# ServiceDesk — Full-Stack Docker Environment
# Copy to .env and adjust values for your deployment.
# ══════════════════════════════════════════════════════════

# ── General ──────────────────────────────────────────────
NODE_ENV=production
TZ=Asia/Riyadh
LOG_LEVEL=info

# ── Nginx ────────────────────────────────────────────────
NGINX_PORT=80

# ── Frontend (baked into Next.js at build time) ──────────
# These should point to the public-facing nginx URL.
NEXT_PUBLIC_API_URL=http://localhost/api/v2
NEXT_PUBLIC_API_BASE_URL=http://localhost
NEXT_PUBLIC_SOCKET_URL=http://localhost

# ── Backend API ──────────────────────────────────────────
BASE_URL=http://localhost
CORS_ORIGIN=http://localhost

# Auth
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRE=30d

# ── MongoDB ──────────────────────────────────────────────
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123

# ── Redis ────────────────────────────────────────────────
REDIS_PORT=6380

# ── PostgreSQL ───────────────────────────────────────────
POSTGRES_USER=servicedesk
POSTGRES_PASSWORD=servicedesk123
POSTGRES_DB=servicedesk
POSTGRES_PORT=5433

# ── MinIO ────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_DEFAULT_BUCKET=servicedesk-files
MINIO_PUBLIC_URL=http://localhost:9000

# ── Kafka / Redpanda ────────────────────────────────────
KAFKA_ENABLED=true
KAFKA_BROKERS=redpanda:9092
KAFKA_CLIENT_ID=servicedesk-backend
KAFKA_CONSUMER_GROUP=servicedesk-consumers
KAFKA_CONNECTION_TIMEOUT=3000
KAFKA_REQUEST_TIMEOUT=30000
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_SSL_ENABLED=false

# ── Database Strategy (mongodb or postgresql per module) ─
DB_STRATEGY_ITSM=mongodb
DB_STRATEGY_PM=mongodb
DB_STRATEGY_FORMS=mongodb
DB_STRATEGY_WORKFLOW=mongodb
DB_STRATEGY_PLATFORM=mongodb
DB_STRATEGY_ANALYTICS=mongodb

# ── Workflow Engine ──────────────────────────────────────
WORKFLOW_ENGINE_MODE=local

# ── Integrations (all disabled by default) ───────────────
SMTP_ENABLED=false
SLACK_ENABLED=false
TEAMS_ENABLED=false
GITHUB_ENABLED=false
GITLAB_ENABLED=false
CICD_WEBHOOK_ENABLED=false
ALERT_WEBHOOK_ENABLED=false
HEARTBEAT_ENABLED=false

# ── Optional Tools ───────────────────────────────────────
CONSOLE_PORT=8085
